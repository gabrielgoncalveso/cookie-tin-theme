    "foreground": "#F1EBDD",
    "descriptionForeground": "#AAA3B1",
    "errorForeground": "#D6979D",
    "editor.background": "#271F3D",
    "editor.foreground": "#F1EBDD",
    "editorCursor.foreground": "#DDD5C0",
    "editor.lineHighlightBackground": "#302A43",
    "editor.selectionBackground": "#464378AA",
    "editor.inactiveSelectionBackground": "#46437866",
    "editor.selectionHighlightBackground": "#B397CA33",
    "editor.findMatchBackground": "#B397CA99",
    "editor.findMatchHighlightBackground": "#B397CA44",
    "editorBracketMatch.background": "#5D525899",
    "editorBracketMatch.border": "#DDD5C0",
    "editorLineNumber.foreground": "#756D80",
    "editorLineNumber.activeForeground": "#DDD5C0",
    "editorWhitespace.foreground": "#5D525866",
    "editorIndentGuide.background1": "#5D525855",
    "editorIndentGuide.activeBackground1": "#B397CA66",
    "editorWidget.background": "#302A43",
    "editorWidget.border": "#5D5258",
    "editorSuggestWidget.selectedBackground": "#46437888",
    "textLink.foreground": "#DDD5C0",
    "textLink.activeForeground": "#F1EBDD",
    "activityBar.background": "#302A43",
    "activityBar.foreground": "#DDD5C0",
    "activityBar.inactiveForeground": "#AAA3B1",
    "activityBarBadge.background": "#B397CA",
    "activityBarBadge.foreground": "#271F3D",
    "sideBar.background": "#302A43", //ESSE
    "sideBar.foreground": "#D4CED8",
    "sideBarTitle.foreground": "#DDD5C0",
    "sideBarSectionHeader.background": "#302A43",
    "sideBarSectionHeader.foreground": "#DDD5C0",
    "list.activeSelectionBackground": "#464378",
    "list.activeSelectionForeground": "#F1EBDD",
    "list.inactiveSelectionBackground": "#46437888",
    "list.hoverBackground": "#5D525855",
    "list.highlightForeground": "#DDD5C0",
    "titleBar.activeBackground": "#302A43",
    "titleBar.inactiveBackground": "#302A43",
    "titleBar.activeForeground": "#DDD5C0",
    "statusBar.background": "#302A43",
    "statusBar.foreground": "#F1EBDD",
    "statusBar.debuggingBackground": "#B397CA",
    "statusBar.debuggingForeground": "#271F3D",
    "statusBarItem.hoverBackground": "#5D5258",
    "tab.activeBackground": "#271F3D",
    "tab.activeForeground": "#F1EBDD",
    "tab.inactiveBackground": "#302A43",
    "tab.inactiveForeground": "#AAA3B1",
    "tab.activeBorderTop": "#DDD5C0",
    "tab.border": "#5D525855",
    "editorGroupHeader.tabsBackground": "#302A43",
    "button.background": "#464378",
    "button.foreground": "#F1EBDD",
    "button.hoverBackground": "#5B568E",
    "button.secondaryBackground": "#5D5258",
    "button.secondaryForeground": "#F1EBDD",
    "button.secondaryHoverBackground": "#6D6168",
    "input.background": "#3A373E",
    "input.foreground": "#F1EBDD",
    "input.border": "#5D5258",
    "dropdown.background": "#3A373E",
    "dropdown.foreground": "#F1EBDD",
    "dropdown.border": "#5D5258",
    "badge.background": "#B397CA",
    "badge.foreground": "#271F3D",
    "progressBar.background": "#DDD5C0",
    "notificationCenterHeader.background": "#3A373E",
    "notifications.background": "#302A43",
    "notifications.border": "#5D5258",
    "terminal.background": "#271F3D",
    "terminal.foreground": "#F1EBDD",
    "terminalCursor.foreground": "#DDD5C0"
  },
  "tokenColors": [
    {
      "name": "Comments",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "fontStyle": "italic", "foreground": "#AAA3B1" }
    },
    {
      "name": "Keywords",
      "scope": ["keyword", "storage", "storage.type", "storage.modifier"],
      "settings": { "foreground": "#B397CA" }
    },
    {
      "name": "Strings",
      "scope": ["string", "constant.other.symbol"],
      "settings": { "foreground": "#D9C79C" }
    },
    {
      "name": "Numbers and constants",
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.escape"
      ],
      "settings": { "foreground": "#D6979D" }
    },
    {
      "name": "Functions",
      "scope": [
        "entity.name.function",
        "meta.function-call",
        "variable.function",
        "support.function"
      ],
      "settings": { "foreground": "#C9C0F0" }
    },
    {
      "name": "Types and classes",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class"
      ],
      "settings": { "foreground": "#DDD5C0" }
    },
    {
      "name": "Variables",
      "scope": ["variable", "support.variable"],
      "settings": { "foreground": "#F1EBDD" }
    },
    {
      "name": "Tags and attributes",
      "scope": ["entity.name.tag", "entity.other.attribute-name"],
      "settings": { "foreground": "#D9B1C8" }
    },
    {
      "name": "Operators and punctuation",
      "scope": ["keyword.operator", "punctuation", "meta.tag"],
      "settings": { "foreground": "#C7BEC5" }
    },
    {
      "name": "Invalid",
      "scope": ["invalid", "invalid.illegal"],
      "settings": { "foreground": "#F0B4B8" }
    }
  ]
}
