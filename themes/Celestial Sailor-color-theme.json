    "button.secondaryForeground": "#F1EBDD",
    "button.secondaryHoverBackground": "#76617F",
    "input.background": "#302040",
    "input.foreground": "#F1EBDD",
    "input.border": "#66536E",
    "dropdown.background": "#302040",
    "dropdown.foreground": "#F1EBDD",
    "dropdown.border": "#66536E",
    "badge.background": "#C3A2F2",
    "badge.foreground": "#21172F",
    "progressBar.background": "#DDD5C0",
    "notificationCenterHeader.background": "#42334A",
    "notifications.background": "#352452",
    "notifications.border": "#66536E",
    "terminal.background": "#21172F",
    "terminal.foreground": "#F1EBDD",
    "terminalCursor.foreground": "#DDD5C0"
  },
  "tokenColors": [
    {
      "name": "Comments",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "fontStyle": "italic", "foreground": "#B4A9C4" }
    },
    {
      "name": "Keywords",
      "scope": ["keyword", "storage", "storage.type", "storage.modifier"],
      "settings": { "foreground": "#C3A2F2" }
    },
    {
      "name": "Strings",
      "scope": ["string", "constant.other.symbol"],
      "settings": { "foreground": "#D9C79C" }
    },
    {
      "name": "Numbers and constants",
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.escape"
      ],
      "settings": { "foreground": "#D6979D" }
    },
    {
      "name": "Functions",
      "scope": [
        "entity.name.function",
        "meta.function-call",
        "variable.function",
        "support.function"
      ],
      "settings": { "foreground": "#D2B8FF" }
    },
    {
      "name": "Types and classes",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class"
      ],
      "settings": { "foreground": "#DDD5C0" }
    },
    {
      "name": "Variables",
      "scope": ["variable", "support.variable"],
      "settings": { "foreground": "#F1EBDD" }
    },
    {
      "name": "Tags and attributes",
      "scope": ["entity.name.tag", "entity.other.attribute-name"],
      "settings": { "foreground": "#DDB6D5" }
    },
    {
      "name": "Operators and punctuation",
      "scope": ["keyword.operator", "punctuation", "meta.tag"],
      "settings": { "foreground": "#CEC3D2" }
    },
    {
      "name": "Invalid",
      "scope": ["invalid", "invalid.illegal"],
      "settings": { "foreground": "#F0B4B8" }
    }
  ]
}
