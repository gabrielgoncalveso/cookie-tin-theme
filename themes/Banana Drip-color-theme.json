    "terminal.background": "#232038",
    "terminal.foreground": "#F2E8D2",
    "terminalCursor.foreground": "#E8C95A"
  },
  "tokenColors": [
    {
      "name": "Comments",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "fontStyle": "italic", "foreground": "#CDBD91" }
    },
    {
      "name": "Keywords",
      "scope": ["keyword", "storage", "storage.type", "storage.modifier"],
      "settings": { "foreground": "#E8C95A" }
    },
    {
      "name": "Strings",
      "scope": ["string", "constant.other.symbol"],
      "settings": { "foreground": "#A9D18E" }
    },
    {
      "name": "Numbers and constants",
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.escape"
      ],
      "settings": { "foreground": "#F0A0A8" }
    },
    {
      "name": "Functions",
      "scope": [
        "entity.name.function",
        "meta.function-call",
        "variable.function",
        "support.function"
      ],
      "settings": { "foreground": "#8FC7E8" }
    },
    {
      "name": "Types and classes",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class"
      ],
      "settings": { "foreground": "#D6B3F0" }
    },
    {
      "name": "Variables",
      "scope": ["variable", "support.variable"],
      "settings": { "foreground": "#F2E8D2" }
    },
    {
      "name": "Tags and attributes",
      "scope": ["entity.name.tag", "entity.other.attribute-name"],
      "settings": { "foreground": "#F2A65A" }
    },
    {
      "name": "Operators and punctuation",
      "scope": ["keyword.operator", "punctuation", "meta.tag"],
      "settings": { "foreground": "#D5C8A8" }
    },
    {
      "name": "Invalid",
      "scope": ["invalid", "invalid.illegal"],
      "settings": { "foreground": "#F0B4B8" }
    }
  ]
}
