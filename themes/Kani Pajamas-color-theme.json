    "terminal.background": "#241A24",
    "terminal.foreground": "#F3E8E1",
    "terminalCursor.foreground": "#FFB0B7"
  },
  "tokenColors": [
    {
      "name": "Comments",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "fontStyle": "italic", "foreground": "#C8A9AE" }
    },
    {
      "name": "Keywords",
      "scope": ["keyword", "storage", "storage.type", "storage.modifier"],
      "settings": { "foreground": "#F08A92" }
    },
    {
      "name": "Strings",
      "scope": ["string", "constant.other.symbol"],
      "settings": { "foreground": "#E7C09E" }
    },
    {
      "name": "Numbers and constants",
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.escape"
      ],
      "settings": { "foreground": "#FFB0B7" }
    },
    {
      "name": "Functions",
      "scope": [
        "entity.name.function",
        "meta.function-call",
        "variable.function",
        "support.function"
      ],
      "settings": { "foreground": "#FFC6CA" }
    },
    {
      "name": "Types and classes",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class"
      ],
      "settings": { "foreground": "#FFE1DC" }
    },
    {
      "name": "Variables",
      "scope": ["variable", "support.variable"],
      "settings": { "foreground": "#F3E8E1" }
    },
    {
      "name": "Tags and attributes",
      "scope": ["entity.name.tag", "entity.other.attribute-name"],
      "settings": { "foreground": "#F6A8C2" }
    },
    {
      "name": "Operators and punctuation",
      "scope": ["keyword.operator", "punctuation", "meta.tag"],
      "settings": { "foreground": "#D8C3C7" }
    },
    {
      "name": "Invalid",
      "scope": ["invalid", "invalid.illegal"],
      "settings": { "foreground": "#FFD0D4" }
    }
  ]
}
